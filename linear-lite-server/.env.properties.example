# Local development template.
# Copy this file to .env.properties and adjust values for your machine.
# DO NOT commit .env.properties.

# --- Server ---
SERVER_PORT=9080

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=linear_lite
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# --- JWT (dev-only fallback secret) ---
JWT_SECRET=linear-lite-dev-secret
JWT_EXPIRATION_MS=86400000

# --- Mail (optional in local dev) ---
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SMTP_AUTH=true
MAIL_SMTP_SSL_ENABLE=true
MAIL_SMTP_STARTTLS_ENABLE=false

# --- Storage / R2 (optional in local dev) ---
STORAGE_MAX_DOWNLOAD_BYTES=10485760
R2_ENABLED=false
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_REGION=auto
